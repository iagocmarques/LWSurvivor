{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "xiaomi-token-plan-sgp/mimo-v2.5-pro",
  "small_model": "xiaomi-token-plan-sgp/mimo-v2.5-flash",
  "default_agent": "workflow-orchestrator",
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "bash": {
      "rm -rf /": "deny",
      "rm -rf ~": "deny",
      "rm -rf *": "deny",
      "mkfs.*": "deny",
      "dd if=* of=/dev/*": "deny",
      ":(){ :|:& };:": "deny",
      "git push --force origin main": "deny",
      "git push --force origin master": "deny",
      "shutdown": "deny",
      "reboot": "deny",
      "halt": "deny",
      "poweroff": "deny",
      "*": "ask"
    },
    "edit": {
      "*.lock": "deny",
      "Assets/**/*.cs": "allow",
      "Assets/**/*.prefab": "ask",
      "Assets/**/*.unity": "ask",
      "*.asset": "ask",
      "kilo.json": "ask",
      "AGENTS.md": "ask",
      ".kilo/**": "ask",
      "*": "ask"
    },
    "external_directory": "deny"
  },
  "mcp": {
    "unity-mcp": {
      "type": "local",
      "command": ["C:\\Users\\Iago\\.unity\\relay\\relay_win.exe", "--mcp"],
      "enabled": true
    }
  },
  "skills": {
    "paths": [".kilo/skill"]
  }
}
